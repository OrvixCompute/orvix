# Environment overrides for the Orvix Node (take precedence over config.yaml).
# Every NodeConfig field can be set via ORVIX_NODE_<FIELD_UPPERCASE>.

# ORVIX_NODE_PROVIDER_ID=your-provider-id
# ORVIX_NODE_NODE_SECRET=your-node-secret
# ORVIX_NODE_ORCHESTRATOR_URL=ws://localhost:8000
# ORVIX_NODE_MODEL=qwen-2.5-7b
# ORVIX_NODE_MAX_CONCURRENT_JOBS=4
# ORVIX_NODE_LOG_LEVEL=INFO

# Development helpers:
# ORVIX_NODE_STUB_GPU=true       # simulate a GPU on machines without one
# ORVIX_NODE_BACKEND=mock        # "mock" or "vllm"
