# ============================================================================
# Orvix Orchestrator — environment configuration
# Copy to `.env` and fill in your values. Never commit `.env`.
# ============================================================================

# --- Core (required) --------------------------------------------------------
# Supabase project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=https://your-project.supabase.co
# Supabase service_role key (server-side ONLY — bypasses RLS). Keep secret.
SUPABASE_SERVICE_KEY=your-service-role-key
# Secret used to sign JWTs (use a long random string, e.g. `openssl rand -hex 32`)
JWT_SECRET=change-me-to-a-long-random-secret
# Runtime environment: dev | prod  (controls log format)
ENVIRONMENT=dev

# --- Core (optional) --------------------------------------------------------
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Comma-separated allowed CORS origins, or "*" for all
CORS_ORIGINS=*

# --- Auth (optional, sensible defaults) -------------------------------------
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# --- Solana / billing (required only for Prompt 6 payment listener) ---------
# Treasury wallet that receives USDC deposits
TREASURY_WALLET_ADDRESS=
# SPL mint address of USDC (mainnet: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v;
# for local testing, use a devnet test mint you control)
USDC_MINT_ADDRESS=
# Helius API key and RPC base URL
HELIUS_API_KEY=
HELIUS_RPC_URL=https://mainnet.helius-rpc.com
# How often the payment listener polls (seconds)
POLLING_INTERVAL_SECONDS=15
# Set to true to start the on-chain payment listener at startup
ENABLE_PAYMENT_LISTENER=false

# --- Provider / payouts (optional, sensible defaults) -----------------------
# Percentage of each job's cost paid out to the provider (the rest is protocol margin)
PROVIDER_REWARD_PERCENTAGE=70
# Minimum USDC a provider must accumulate before requesting a withdrawal
MIN_WITHDRAW_AMOUNT_USDC=100.0
# Withdrawals above this amount require manual approval
AUTO_APPROVE_MAX_USDC=10000.0
# Per-user daily withdrawal cap
MAX_WITHDRAWALS_PER_DAY=5
# Simulate on-chain payouts instead of sending real USDC transactions.
# Keep true until the treasury keypair is configured and real payouts are vetted.
PAYOUT_STUB=true
# How often the payout worker processes the withdrawal queue (seconds)
PAYOUT_INTERVAL_SECONDS=300
# Path to the treasury keypair file (ONLY used when PAYOUT_STUB=false)
TREASURY_KEYPAIR_PATH=
# Set to true to start the withdrawal payout worker at startup
ENABLE_PAYOUT_WORKER=false
