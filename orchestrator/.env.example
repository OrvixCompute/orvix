# ============================================================================
# Orvix Orchestrator — environment configuration
# Copy to `.env` and fill in your values. Never commit `.env`.
# ============================================================================

# --- Core (required) --------------------------------------------------------
# Supabase project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=https://your-project.supabase.co
# Supabase service_role key (server-side ONLY — bypasses RLS). Keep secret.
SUPABASE_SERVICE_KEY=your-service-role-key
# Secret used to sign JWTs (use a long random string, e.g. `openssl rand -hex 32`)
JWT_SECRET=change-me-to-a-long-random-secret
# Runtime environment: dev | prod  (controls log format)
ENVIRONMENT=dev

# --- Core (optional) --------------------------------------------------------
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Comma-separated allowed CORS origins, or "*" for all
CORS_ORIGINS=*

# --- Auth (optional, sensible defaults) -------------------------------------
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# --- Solana / billing (required only for Prompt 6 payment listener) ---------
# Treasury wallet that receives USDC deposits
TREASURY_WALLET_ADDRESS=
# SPL mint address of USDC (mainnet: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v;
# for local testing, use a devnet test mint you control)
USDC_MINT_ADDRESS=
# SPL mint address of ORVX (used to detect provider staking deposits)
ORVX_MINT_ADDRESS=
# Helius API key and RPC base URL
HELIUS_API_KEY=
HELIUS_RPC_URL=https://mainnet.helius-rpc.com
# How often the payment listener polls (seconds)
POLLING_INTERVAL_SECONDS=15
# Set to true to start the on-chain payment listener at startup
ENABLE_PAYMENT_LISTENER=false

# --- Provider / payouts (optional, sensible defaults) -----------------------
# Percentage of each job's cost paid out to the provider (the rest is protocol margin)
PROVIDER_REWARD_PERCENTAGE=70
# Minimum USDC a provider must accumulate before requesting a withdrawal
MIN_WITHDRAW_AMOUNT_USDC=100.0
# Withdrawals above this amount require manual approval
AUTO_APPROVE_MAX_USDC=10000.0
# Per-user daily withdrawal cap
MAX_WITHDRAWALS_PER_DAY=5
# Simulate on-chain payouts instead of sending real USDC transactions.
# Keep true until the treasury keypair is configured and real payouts are vetted.
PAYOUT_STUB=true
# How often the payout worker processes the withdrawal queue (seconds)
PAYOUT_INTERVAL_SECONDS=300
# Path to the treasury keypair file (ONLY used when PAYOUT_STUB=false)
TREASURY_KEYPAIR_PATH=
# Set to true to start the withdrawal payout worker at startup
ENABLE_PAYOUT_WORKER=false

# --- Staking / tokenomics (whitepaper alignment) ----------------------------
# Minimum ORVX a user must stake to register as a compute provider
PROVIDER_MIN_STAKE_ORVX=25000
# How long a staking intent (and its memo) stays valid, in minutes
STAKE_INTENT_TTL_MINUTES=30
# Shared secret for admin buyback/burn endpoints (X-Admin-Key header).
# Generate once, e.g. `openssl rand -hex 32`. Leave blank to disable those endpoints.
ADMIN_API_KEY=

# --- Buyback & burn (admin tooling) -----------------------------------------
# On-chain decimals of the ORVX / USDC SPL tokens
ORVX_DECIMALS=6
USDC_DECIMALS=6
# Simulate on-chain actions instead of sending real transactions.
# Keep BOTH true until devnet-tested and the treasury keypair is configured.
BUYBACK_STUB=true
BURN_STUB=true
# Abort a buyback if Jupiter price impact exceeds this (basis points)
BUYBACK_MAX_SLIPPAGE_BPS=100
# Minimum seconds between buyback executions (drain guard)
BUYBACK_MIN_INTERVAL_SECONDS=300
# Jupiter v6 quote/swap API base URL
JUPITER_QUOTE_API=https://quote-api.jup.ag/v6
# Solana incinerator address (burns SPL tokens sent to it)
INCINERATOR_ADDRESS=1nc1nerator11111111111111111111111111111111
# If set, buyback/burn executions are appended to dated audit files in this dir
AUDIT_LOG_DIR=

# --- Governance (Snapshot.org) ----------------------------------------------
GOVERNANCE_SNAPSHOT_SPACE=orvix
GOVERNANCE_SNAPSHOT_URL=https://snapshot.box/#/orvix
